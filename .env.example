# ==============================================================================
# Antigravity Banking Management System - Environment Variables Example
# Copy this file to '.env' and modify settings for local development.
# When deploying to Azure App Service, configure these as Application Settings.
# ==============================================================================

# 1. FastAPI Settings
PROJECT_NAME="Monolithic Banking Management System"

# 2. Security (Generate strong random values in production)
SECRET_KEY="supersecretjwtkeyforbankingapplication123456!"
REFRESH_SECRET_KEY="supersecretrefreshjwtkeyforbankingapplication123456!"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080 # 7 days (60 * 24 * 7)

# 3. Database URL (PostgreSQL)
# Local PostgreSQL format: postgresql://username:password@localhost:5432/dbname
# SQLite Local Fallback: If not specified or if port 5432 is not accessible locally,
# the application will fall back to local sqlite (sqlite:///./banking_db.db).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/banking_db"

# 4. Azure Blob Storage Integration (GRS)
# Keep empty to use local fallback directory (static/uploads/) for KYC/statements.
# Provide active connection string when deploying to Azure.
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_CONTAINER_NAME="banking-documents"
